# ─────────────────────────────────────────────────────────────
# Database — TimescaleDB
# ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://obe_user:obe_pass@localhost:5432/obe_db

# ─────────────────────────────────────────────────────────────
# JWT Authentication
# ─────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=your-super-secret-jwt-key-minimum-32-characters-change-this
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ─────────────────────────────────────────────────────────────
# Redis (Celery Broker + Order Book Cache)
# ─────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1

# ─────────────────────────────────────────────────────────────
# App Settings
# ─────────────────────────────────────────────────────────────
APP_NAME=OrderBookExpert
APP_VERSION=1.0.0
DEBUG=true
ALLOWED_ORIGINS=http://localhost:3000

# ─────────────────────────────────────────────────────────────
# Exchange API Keys (encrypted and stored in DB — these are defaults)
# ─────────────────────────────────────────────────────────────
BINANCE_API_KEY=
BINANCE_API_SECRET=
